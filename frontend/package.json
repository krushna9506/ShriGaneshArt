{
  "name": "ganesha-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "build:android": "npm run build && npx cap sync android",
    "open:android": "npx cap open android",
    "run:android": "npm run build && npx cap sync android && npx cap run android",
    "build:ios": "npm run build && npx cap sync ios",
    "open:ios": "npx cap open ios",
    "run:ios": "npm run build && npx cap sync ios && npx cap run ios",
    "deploy:web": "npm run build && vercel --prod",
    "cap:update": "npm run build && npx cap sync"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/network": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "axios": "^1.7.7",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.20",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.3.0"
  }
}
