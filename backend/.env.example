# Neon PostgreSQL (get from neon.tech dashboard)
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# JWT (generate any long random string)
JWT_SECRET=your_super_long_random_secret_here_minimum_32_chars

# Supabase Storage only (get from supabase.com dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Vercel frontend URL (update after Vercel deploy)
FRONTEND_URL=https://ganesh-arts.vercel.app

# Set automatically by Render, do not set manually
# PORT=3000

NODE_ENV=production
